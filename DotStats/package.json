{
  "name": "dotstats",
  "version": "0.2.1",
  "description": "DotStats - 数据看板桌面端",
  "main": "dist-electron/main.js",
  "author": "wjpyinuo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wjpyinuo/DotTranslator.git",
    "directory": "DotStats"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron:dev": "vite && electron .",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "echarts": "^5.5.0",
    "echarts-for-react": "^3.0.0",
    "axios": "^1.7.0",
    "zustand": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.4.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  },
  "build": {
    "appId": "com.dotstats.app",
    "productName": "DotStats",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true
    }
  }
}
