# DotStats Analytics Server - Environment Variables
# Copy this file to .env and fill in the values

# Server
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
SHUTDOWN_TIMEOUT_MS=10000

# Database
DB_PASSWORD=change_me_to_a_strong_password
DATABASE_URL=postgresql://dotstats:change_me_to_a_strong_password@localhost:5432/dotstats

# Redis
REDIS_URL=redis://localhost:6379

# Auth
ADMIN_API_KEY=change_me_to_a_random_string
WS_TOKEN=change_me_to_another_random_string

# CORS (comma-separated origins, empty = deny all)
CORS_ORIGIN=http://localhost:5174

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute
