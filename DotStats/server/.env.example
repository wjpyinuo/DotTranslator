# DotStats Server Environment Variables

# Database
DB_PASSWORD=your-strong-password-here
DATABASE_URL=postgresql://dotstats:your-strong-password-here@db:5432/dotstats

# Redis
REDIS_URL=redis://redis:6379

# Server
PORT=3000
LOG_LEVEL=info

# Security (required for admin API)
ADMIN_API_KEY=generate-a-random-key-here

# CORS (comma-separated allowed origins, leave empty to disable cross-origin)
CORS_ORIGIN=http://localhost:5173
