<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DotTranslator.App.ViewModels"
             x:Class="DotTranslator.App.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <ScrollViewer Padding="16">
    <StackPanel Spacing="16">
      <TextBlock Text="设置" FontSize="20" FontWeight="Bold" />

      <!-- API Keys Section -->
      <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
              CornerRadius="8" Padding="16">
        <StackPanel Spacing="12">
          <TextBlock Text="🔑 API Key 配置" FontSize="16" FontWeight="SemiBold" />

          <StackPanel>
            <TextBlock Text="DeepL API Key" FontSize="12" />
            <TextBox Text="{Binding DeeplApiKey}" PasswordChar="*" Watermark="输入 DeepL API Key" />
          </StackPanel>

          <StackPanel>
            <TextBlock Text="有道 App ID" FontSize="12" />
            <TextBox Text="{Binding YoudaoAppId}" Watermark="输入有道智云 App ID" />
          </StackPanel>

          <StackPanel>
            <TextBlock Text="有道 App Secret" FontSize="12" />
            <TextBox Text="{Binding YoudaoAppSecret}" PasswordChar="*" Watermark="输入有道智云 App Secret" />
          </StackPanel>

          <StackPanel>
            <TextBlock Text="百度 App ID" FontSize="12" />
            <TextBox Text="{Binding BaiduAppId}" Watermark="输入百度翻译 App ID" />
          </StackPanel>

          <StackPanel>
            <TextBlock Text="百度密钥" FontSize="12" />
            <TextBox Text="{Binding BaiduSecretKey}" PasswordChar="*" Watermark="输入百度翻译密钥" />
          </StackPanel>

          <Button Content="保存 API Keys" Command="{Binding SaveApiKeysCommand}" HorizontalAlignment="Left" />
        </StackPanel>
      </Border>

      <!-- Theme Section -->
      <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
              CornerRadius="8" Padding="16">
        <StackPanel Spacing="12">
          <TextBlock Text="🎨 外观" FontSize="16" FontWeight="SemiBold" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <RadioButton Content="浅色" IsChecked="{Binding Theme, Converter={x:Static vm:Converters.ThemeLightConverter}}" />
            <RadioButton Content="深色" IsChecked="{Binding Theme, Converter={x:Static vm:Converters.ThemeDarkConverter}}" />
            <RadioButton Content="跟随系统" IsChecked="{Binding Theme, Converter={x:Static vm:Converters.ThemeSystemConverter}}" />
          </StackPanel>
          <Button Content="应用主题" Command="{Binding SaveThemeCommand}" HorizontalAlignment="Left" />
        </StackPanel>
      </Border>

      <!-- Data Management -->
      <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
              CornerRadius="8" Padding="16">
        <StackPanel Spacing="12">
          <TextBlock Text="📦 数据管理" FontSize="16" FontWeight="SemiBold" />
          <Button Content="清除所有历史记录" Command="{Binding ClearAllDataCommand}"
                  HorizontalAlignment="Left" />
        </StackPanel>
      </Border>

      <!-- About -->
      <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
              CornerRadius="8" Padding="16">
        <StackPanel Spacing="8">
          <TextBlock Text="ℹ️ 关于" FontSize="16" FontWeight="SemiBold" />
          <TextBlock Text="{Binding AppVersion, StringFormat='DotTranslator v{0}'}" />
          <TextBlock Text="即时翻译桌面工具 · .NET 8 + Avalonia" FontSize="12"
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        </StackPanel>
      </Border>

      <!-- Status -->
      <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                 Foreground="{DynamicResource SystemControlForegroundAccentBrush}" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
