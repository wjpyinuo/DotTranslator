<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DotTranslator.App.Controls.TitleBar"
             Height="36" Background="Transparent">

  <Grid ColumnDefinitions="*,Auto,Auto,Auto">
    <!-- Drag area -->
    <Border Grid.Column="0" x:Name="DragArea" Background="Transparent" />

    <!-- Window controls -->
    <Button Grid.Column="1" Content="—"
            Click="OnMinimize" FontSize="14" Width="40" Height="36"
            Background="Transparent" />
    <Button Grid.Column="2" Content="□"
            Click="OnMaximize" FontSize="12" Width="40" Height="36"
            Background="Transparent" />
    <Button Grid.Column="3" Content="✕"
            Click="OnClose" FontSize="14" Width="40" Height="36"
            Background="Transparent" />
  </Grid>
</UserControl>
