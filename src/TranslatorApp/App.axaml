<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="using:TranslatorApp.Converters"
             x:Class="TranslatorApp.App">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://DotTranslator/Assets/Themes/Colors.axaml" />
        <ResourceInclude Source="avares://DotTranslator/Assets/Themes/Neumorphism/Button.axaml" />
        <ResourceInclude Source="avares://DotTranslator/Assets/Themes/Neumorphism/TextBox.axaml" />
        <ResourceInclude Source="avares://DotTranslator/Assets/Themes/Neumorphism/BorderCard.axaml" />
        <ResourceInclude Source="avares://DotTranslator/Assets/Themes/Neumorphism/Badge.axaml" />
      </ResourceDictionary.MergedDictionaries>
      <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />
  </Application.Styles>

</Application>
