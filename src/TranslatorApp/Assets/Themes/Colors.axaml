<!--
  DotTranslator — Neumorphism 设计系统色彩 Token
  用法：在 App.axaml 中合并此 ResourceDictionary
  引用：{DynamicResource BgBrush} / {DynamicResource AccentColor}
-->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib"
                    x:Class="TranslatorApp.Assets.Themes.Colors">

  <!-- ═══════════════════════════════════════════
       共享颜色键值（深色主题切换时通过代码替换 Brush.Color）
       ═══════════════════════════════════════════ -->
  <Color x:Key="Light.Bg">#E0E5EC</Color>
  <Color x:Key="Light.ShadowLight">#FFFFFF</Color>
  <Color x:Key="Light.ShadowDark">#B8C0CC</Color>
  <Color x:Key="Light.TextPrimary">#2D3436</Color>
  <Color x:Key="Light.TextSecondary">#636E72</Color>
  <Color x:Key="Light.TextDisabled">#A0A8B0</Color>
  <Color x:Key="Light.Accent">#6C5CE7</Color>
  <Color x:Key="Light.AccentHover">#5A4BD6</Color>
  <Color x:Key="Light.AccentPressed">#4839B0</Color>
  <Color x:Key="Light.Success">#00B894</Color>
  <Color x:Key="Light.Warning">#FDCB6E</Color>
  <Color x:Key="Light.Error">#E17055</Color>
  <Color x:Key="Light.CardBg">#E0E5EC</Color>
  <Color x:Key="Light.InputBg">#E0E5EC</Color>
  <Color x:Key="Light.Divider">#C8CDD5</Color>

  <Color x:Key="Dark.Bg">#2B2D42</Color>
  <Color x:Key="Dark.ShadowLight">#383A54</Color>
  <Color x:Key="Dark.ShadowDark">#1E2030</Color>
  <Color x:Key="Dark.TextPrimary">#DFE6E9</Color>
  <Color x:Key="Dark.TextSecondary">#B2BEC3</Color>
  <Color x:Key="Dark.TextDisabled">#6C7380</Color>
  <Color x:Key="Dark.Accent">#A29BFE</Color>
  <Color x:Key="Dark.AccentHover">#8B84FC</Color>
  <Color x:Key="Dark.AccentPressed">#7470E0</Color>
  <Color x:Key="Dark.Success">#55EFC4</Color>
  <Color x:Key="Dark.Warning">#FFEAA7</Color>
  <Color x:Key="Dark.Error">#FF7675</Color>
  <Color x:Key="Dark.CardBg">#2B2D42</Color>
  <Color x:Key="Dark.InputBg">#2B2D42</Color>
  <Color x:Key="Dark.Divider">#3D3F58</Color>

  <!-- ═══════════════════════════════════════════
       主题 Brush（默认浅色，切换时通过 Colors.ApplyTheme 替换 .Color）
       ═══════════════════════════════════════════ -->
  <SolidColorBrush x:Key="BgBrush"             Color="#E0E5EC" />
  <SolidColorBrush x:Key="ShadowLightBrush"    Color="#FFFFFF" />
  <SolidColorBrush x:Key="ShadowDarkBrush"     Color="#B8C0CC" />
  <SolidColorBrush x:Key="TextPrimaryBrush"    Color="#2D3436" />
  <SolidColorBrush x:Key="TextSecondaryBrush"  Color="#636E72" />
  <SolidColorBrush x:Key="TextDisabledBrush"   Color="#A0A8B0" />
  <SolidColorBrush x:Key="AccentBrush"         Color="#6C5CE7" />
  <SolidColorBrush x:Key="AccentHoverBrush"    Color="#5A4BD6" />
  <SolidColorBrush x:Key="AccentPressedBrush"  Color="#4839B0" />
  <SolidColorBrush x:Key="SuccessBrush"        Color="#00B894" />
  <SolidColorBrush x:Key="WarningBrush"        Color="#FDCB6E" />
  <SolidColorBrush x:Key="ErrorBrush"          Color="#E17055" />
  <SolidColorBrush x:Key="CardBgBrush"         Color="#E0E5EC" />
  <SolidColorBrush x:Key="InputBgBrush"        Color="#E0E5EC" />
  <SolidColorBrush x:Key="DividerBrush"        Color="#C8CDD5" />

  <!-- Light Neumorphism Shadows -->
  <!-- default: 6 6 12 / neg 6 6 12, matches HTML outset-shadow -->
  <BoxShadows x:Key="Neu.Outset">6 6 12 #B8C0CC, -6 -6 12 #FFFFFF</BoxShadows>
  <!-- hover: 8 8 16 / neg 8 8 16, matches HTML outset-shadow-hover -->
  <BoxShadows x:Key="Neu.OutsetHover">8 8 16 #B8C0CC, -8 -8 16 #FFFFFF</BoxShadows>
  <!-- small: 3 3 6 / neg 3 3 6, matches HTML outset-shadow-sm -->
  <BoxShadows x:Key="Neu.OutsetSmall">3 3 6 #B8C0CC, -3 -3 6 #FFFFFF</BoxShadows>
  <!-- primary: asymmetric 4 4 8 / neg 2 2 6, matches HTML btn-primary -->
  <BoxShadows x:Key="Neu.OutsetPrimary">4 4 8 #B8C0CC, -2 -2 6 #FFFFFF</BoxShadows>
  <BoxShadows x:Key="Neu.Inset">inset 4 4 8 #B8C0CC, inset -4 -4 8 #FFFFFF</BoxShadows>
  <BoxShadows x:Key="Neu.InsetDeep">inset 6 6 12 #B8C0CC, inset -6 -6 12 #FFFFFF</BoxShadows>
  <BoxShadows x:Key="Neu.Flat">2 2 4 #B8C0CC, -2 -2 4 #FFFFFF</BoxShadows>

  <!-- ═══════════════════════════════════════════
       深色主题 Shadows（ApplyTheme 时替换）
       ═══════════════════════════════════════════ -->
  <BoxShadows x:Key="Dark.Neu.Outset">6 6 12 #1E2030, -6 -6 12 #383A54</BoxShadows>
  <BoxShadows x:Key="Dark.Neu.OutsetHover">8 8 16 #1E2030, -8 -8 16 #383A54</BoxShadows>
  <BoxShadows x:Key="Dark.Neu.OutsetSmall">3 3 6 #1E2030, -3 -3 6 #383A54</BoxShadows>
  <BoxShadows x:Key="Dark.Neu.OutsetPrimary">4 4 8 #1E2030, -2 -2 6 #383A54</BoxShadows>
  <BoxShadows x:Key="Dark.Neu.Inset">inset 4 4 8 #1E2030, inset -4 -4 8 #383A54</BoxShadows>
  <BoxShadows x:Key="Dark.Neu.InsetDeep">inset 6 6 12 #1E2030, inset -6 -6 12 #383A54</BoxShadows>
  <BoxShadows x:Key="Dark.Neu.Flat">2 2 4 #1E2030, -2 -2 4 #383A54</BoxShadows>

  <!-- ═══════════════════════════════════════════
       全局共享 Token（主题无关）
       ═══════════════════════════════════════════ -->
  <CornerRadius x:Key="Radius.Small">8</CornerRadius>
  <CornerRadius x:Key="Radius.Medium">12</CornerRadius>
  <CornerRadius x:Key="Radius.Large">16</CornerRadius>
  <CornerRadius x:Key="Radius.Pill">999</CornerRadius>

  <x:Double x:Key="Space.XS">4</x:Double>
  <x:Double x:Key="Space.S">8</x:Double>
  <x:Double x:Key="Space.M">12</x:Double>
  <x:Double x:Key="Space.L">16</x:Double>
  <x:Double x:Key="Space.XL">24</x:Double>
  <x:Double x:Key="Space.XXL">32</x:Double>

  <x:Double x:Key="FontSize.Caption">10</x:Double>
  <x:Double x:Key="FontSize.Small">12</x:Double>
  <x:Double x:Key="FontSize.Body">14</x:Double>
  <x:Double x:Key="FontSize.BodyLarge">16</x:Double>
  <x:Double x:Key="FontSize.Title">18</x:Double>
  <x:Double x:Key="FontSize.Heading">22</x:Double>

  <system:TimeSpan x:Key="Animation.Fast">00:00:00.150</system:TimeSpan>
  <system:TimeSpan x:Key="Animation.Normal">00:00:00.200</system:TimeSpan>
  <system:TimeSpan x:Key="Animation.Slow">00:00:00.300</system:TimeSpan>

</ResourceDictionary>
