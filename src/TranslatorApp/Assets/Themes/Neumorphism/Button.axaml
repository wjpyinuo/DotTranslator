<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ControlTheme x:Key="NeuButton" TargetType="Button">
    <Setter Property="Background" Value="{DynamicResource CardBgBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}" />
    <Setter Property="Padding" Value="20,10" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="PART_Border"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}"
                Padding="{TemplateBinding Padding}"
                BoxShadow="{DynamicResource Neu.Outset}">
          <ContentPresenter Content="{TemplateBinding Content}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
        </Border>
      </ControlTemplate>
    </Setter>

    <Style Selector="^:pointerover">
      <Style Selector="^ /template/ Border#PART_Border">
        <Setter Property="BoxShadow" Value="{DynamicResource Neu.OutsetHover}" />
        <Setter Property="RenderTransform">
          <TranslateTransform Y="-2" />
        </Setter>
      </Style>
    </Style>

    <Style Selector="^:pressed">
      <Style Selector="^ /template/ Border#PART_Border">
        <Setter Property="BoxShadow" Value="{DynamicResource Neu.Inset}" />
        <Setter Property="RenderTransform">
          <TranslateTransform Y="0" />
        </Setter>
      </Style>
    </Style>

    <Style Selector="^:disabled">
      <Setter Property="Opacity" Value="0.5" />
      <Style Selector="^ /template/ Border#PART_Border">
        <Setter Property="BoxShadow" Value="{DynamicResource Neu.Flat}" />
      </Style>
    </Style>

    <!-- Focus: no visible border, just slight shadow change -->
    <Style Selector="^:focus">
      <Style Selector="^ /template/ Border#PART_Border">
        <Setter Property="BoxShadow" Value="{DynamicResource Neu.OutsetHover}" />
      </Style>
    </Style>

    <!-- accent variant -->
    <Style Selector="^.accent">
      <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Style Selector="^ /template/ Border#PART_Border">
        <Setter Property="BoxShadow" Value="{DynamicResource Neu.OutsetPrimary}" />
      </Style>
      <Style Selector="^:pointerover">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
        <Style Selector="^ /template/ Border#PART_Border">
          <Setter Property="BoxShadow" Value="{DynamicResource Neu.Outset}" />
        </Style>
      </Style>
      <Style Selector="^:pressed">
        <Setter Property="Background" Value="{DynamicResource AccentPressedBrush}" />
        <Style Selector="^ /template/ Border#PART_Border">
          <Setter Property="BoxShadow" Value="{DynamicResource Neu.Inset}" />
        </Style>
      </Style>
    </Style>

    <Style Selector="^.secondary">
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>

    <Style Selector="^.small">
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="FontSize" Value="{DynamicResource FontSize.Small}" />
    </Style>

    <!-- icon: fully round, no border at all -->
    <Style Selector="^.icon">
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Padding" Value="10" />
      <Setter Property="MinWidth" Value="36" />
      <Setter Property="MinHeight" Value="36" />
      <Style Selector="^ /template/ Border#PART_Border">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="CornerRadius" Value="999" />
      </Style>
    </Style>
  </ControlTheme>

  <!-- ═══════════════════════════════════════
       Tab Button (匹配 UI Preview 水平页签)
       ═══════════════════════════════════════ -->
  <ControlTheme x:Key="NeuTabButton" TargetType="Button" BasedOn="{StaticResource NeuButton}">
    <Setter Property="Padding" Value="22,10" />
    <Setter Property="FontSize" Value="{DynamicResource FontSize.Body}" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}" />
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    <Setter Property="Background" Value="{DynamicResource BgBrush}" />
    <Style Selector="^ /template/ Border#PART_Border">
      <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}" />
      <Setter Property="BoxShadow" Value="{DynamicResource Neu.Inset}" />
    </Style>
    <Style Selector="^:pointerover">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Style Selector="^ /template/ Border#PART_Border">
        <Setter Property="BoxShadow" Value="{DynamicResource Neu.Inset}" />
        <Setter Property="RenderTransform" Value="none" />
      </Style>
    </Style>
    <Style Selector="^:pressed">
      <Style Selector="^ /template/ Border#PART_Border">
        <Setter Property="BoxShadow" Value="{DynamicResource Neu.InsetDeep}" />
      </Style>
    </Style>
    <!-- Selected state: outset, accent color -->
    <Style Selector="^.isSelected">
      <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Style Selector="^ /template/ Border#PART_Border">
        <Setter Property="BoxShadow" Value="{DynamicResource Neu.OutsetSmall}" />
      </Style>
    </Style>
  </ControlTheme>

  <!-- ═══════════════════════════════════════
       Translate Main Button (翻译按钮 - 大号强调)
       ═══════════════════════════════════════ -->
  <ControlTheme x:Key="NeuTranslateButton" TargetType="Button" BasedOn="{StaticResource NeuButton}">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Padding" Value="56,12" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Large}" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="Margin" Value="0,8,0,16" />
    <Style Selector="^ /template/ Border#PART_Border">
      <Setter Property="BoxShadow" Value="{DynamicResource Neu.OutsetPrimary}" />
    </Style>
    <Style Selector="^:pointerover">
      <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
      <Style Selector="^ /template/ Border#PART_Border">
        <Setter Property="BoxShadow" Value="{DynamicResource Neu.Outset}" />
        <Setter Property="RenderTransform">
          <TranslateTransform Y="-2" />
        </Setter>
      </Style>
    </Style>
    <Style Selector="^:pressed">
      <Setter Property="Background" Value="{DynamicResource AccentPressedBrush}" />
      <Style Selector="^ /template/ Border#PART_Border">
        <Setter Property="BoxShadow" Value="{DynamicResource Neu.Inset}" />
      </Style>
    </Style>
  </ControlTheme>

</ResourceDictionary>
