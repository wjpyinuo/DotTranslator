<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ControlTheme x:Key="NeuButton" TargetType="Button">
    <Setter Property="Background" Value="{DynamicResource CardBgBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}" />
    <Setter Property="Padding" Value="20,10" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="PART_Border"
                Background="{TemplateBinding Background}"
                CornerRadius="{TemplateBinding CornerRadius}"
                Padding="{TemplateBinding Padding}"
                BoxShadow="{DynamicResource Neu.Outset}">
          <ContentPresenter Content="{TemplateBinding Content}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
        </Border>
      </ControlTemplate>
    </Setter>

    <Style Selector="^:pointerover">
      <Style Selector="^ /template/ Border#PART_Border">
        <Setter Property="BoxShadow" Value="{DynamicResource Neu.OutsetHover}" />
        <Setter Property="RenderTransform">
          <TranslateTransform Y="-2" />
        </Setter>
      </Style>
    </Style>

    <Style Selector="^:pressed">
      <Style Selector="^ /template/ Border#PART_Border">
        <Setter Property="BoxShadow" Value="{DynamicResource Neu.Inset}" />
        <Setter Property="RenderTransform">
          <TranslateTransform Y="0" />
        </Setter>
      </Style>
    </Style>

    <Style Selector="^:disabled">
      <Setter Property="Opacity" Value="0.5" />
      <Style Selector="^ /template/ Border#PART_Border">
        <Setter Property="BoxShadow" Value="{DynamicResource Neu.Flat}" />
      </Style>
    </Style>

    <Style Selector="^:focus">
      <Style Selector="^ /template/ Border#PART_Border">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="2,2" />
      </Style>
    </Style>

    <!-- accent variant -->
    <Style Selector="^.accent">
      <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Style Selector="^ /template/ Border#PART_Border">
        <Setter Property="BoxShadow" Value="{DynamicResource Neu.OutsetPrimary}" />
      </Style>
      <Style Selector="^:pointerover">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
        <Style Selector="^ /template/ Border#PART_Border">
          <Setter Property="BoxShadow" Value="{DynamicResource Neu.Outset}" />
        </Style>
      </Style>
      <Style Selector="^:pressed">
        <Setter Property="Background" Value="{DynamicResource AccentPressedBrush}" />
        <Style Selector="^ /template/ Border#PART_Border">
          <Setter Property="BoxShadow" Value="{DynamicResource Neu.Inset}" />
        </Style>
      </Style>
    </Style>

    <Style Selector="^.secondary">
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>

    <Style Selector="^.small">
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="FontSize" Value="{DynamicResource FontSize.Small}" />
    </Style>

    <Style Selector="^.icon">
      <Setter Property="CornerRadius" Value="{DynamicResource Radius.Pill}" />
      <Setter Property="Padding" Value="10" />
      <Setter Property="MinWidth" Value="36" />
      <Setter Property="MinHeight" Value="36" />
    </Style>
  </ControlTheme>

</ResourceDictionary>
