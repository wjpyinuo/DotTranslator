<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ControlTheme x:Key="NeuCard" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource CardBgBrush}" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Large}" />
    <Setter Property="Padding" Value="16" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="BoxShadow" Value="{DynamicResource Neu.Outset}" />

    <Style Selector="^:pointerover">
      <Setter Property="BoxShadow" Value="{DynamicResource Neu.OutsetHover}" />
      <Setter Property="RenderTransform">
        <TranslateTransform Y="-1" />
      </Setter>
    </Style>

    <Style Selector="^.flat">
      <Setter Property="BoxShadow" Value="{DynamicResource Neu.Flat}" />
    </Style>

    <Style Selector="^.accent">
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
      <Setter Property="BorderThickness" Value="2,2" />
    </Style>

    <Style Selector="^.inset">
      <Setter Property="BoxShadow" Value="{DynamicResource Neu.Inset}" />
    </Style>
  </ControlTheme>

</ResourceDictionary>
