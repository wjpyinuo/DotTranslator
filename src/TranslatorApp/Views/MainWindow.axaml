<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TranslatorApp.ViewModels"
        x:Class="TranslatorApp.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="DotTranslator v1.0.0"
        Width="800" Height="600"
        MinWidth="500" MinHeight="400"
        Background="{DynamicResource BgBrush}"
        SystemDecorations="None"
        TransparencyLevelHint="None">

  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <Grid RowDefinitions="40,*,32">
    <!-- Custom Title Bar (drag region) -->
    <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="12,0"
          x:Name="TitleBar">
      <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <TextBlock Text="🔲 DotTranslator" FontWeight="SemiBold"
                   FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBlock Text="v1.0.0" FontSize="11" Opacity="0.5"
                   VerticalAlignment="Bottom" Foreground="{DynamicResource TextSecondaryBrush}" />
      </StackPanel>
      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                  HorizontalAlignment="Right" VerticalAlignment="Center">
        <Button Content="🌙" Theme="{StaticResource NeuButton}" Classes="icon small"
                ToolTip.Tip="切换主题" Command="{Binding ToggleThemeCommand}" />
        <Button Content="📌" Theme="{StaticResource NeuButton}" Classes="icon small"
                ToolTip.Tip="置顶" Command="{Binding TogglePinCommand}" />
        <Border Width="1" Height="20" Background="{DynamicResource DividerBrush}"
                Margin="4,0" VerticalAlignment="Center" />
        <Button Content="─" Theme="{StaticResource NeuButton}" Classes="icon small"
                Click="MinimizeClick" />
        <Button Content="□" Theme="{StaticResource NeuButton}" Classes="icon small"
                Click="MaximizeClick" />
        <Button Content="✕" Theme="{StaticResource NeuButton}" Classes="icon small"
                Click="CloseClick" />
      </StackPanel>
    </Grid>

    <!-- Main Content -->
    <Grid Grid.Row="1" Margin="16,0">
      <StackPanel Spacing="16" VerticalAlignment="Top" MaxWidth="700" Margin="0,8">

        <!-- Language Selector -->
        <Grid ColumnDefinitions="*,Auto,*">
          <ComboBox ItemsSource="{Binding AvailableLanguages}"
                    SelectedItem="{Binding SelectedSourceLang}"
                    DisplayMemberBinding="{Binding Name}" />
          <Button Grid.Column="1" Content="⇄" Margin="8,0"
                  Theme="{StaticResource NeuButton}" Classes="icon"
                  Command="{Binding SwapLanguagesCommand}" />
          <ComboBox Grid.Column="2" ItemsSource="{Binding AvailableLanguages}"
                    SelectedItem="{Binding SelectedTargetLang}"
                    DisplayMemberBinding="{Binding Name}" />
        </Grid>

        <!-- Input -->
        <TextBox Watermark="在此输入要翻译的文本..."
                 Text="{Binding SourceText}"
                 AcceptsReturn="True" TextWrapping="Wrap"
                 MinHeight="120" MaxHeight="250"
                 FontSize="{DynamicResource FontSize.BodyLarge}"
                 Theme="{StaticResource NeuTextBox}" />

        <!-- Translate Button -->
        <Button Content="⚡ 翻 译"
                Theme="{StaticResource NeuButton}" Classes="accent"
                HorizontalAlignment="Stretch"
                FontSize="{DynamicResource FontSize.BodyLarge}"
                Command="{Binding TranslateCommand}" />

        <!-- Result Card -->
        <Border Theme="{StaticResource NeuCard}"
                IsVisible="{Binding HasResult}">
          <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="{Binding EngineName}" FontWeight="SemiBold" />
              <Border Theme="{StaticResource NeuBadge}" Classes="accent" Padding="8,2">
                <TextBlock Text="{Binding LatencyDisplay}"
                           FontSize="{DynamicResource FontSize.Small}"
                           FontWeight="SemiBold" Foreground="White" />
              </Border>
            </StackPanel>
            <TextBlock Text="{Binding TranslatedText}"
                       FontSize="{DynamicResource FontSize.BodyLarge}"
                       LineHeight="28" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
              <Button Content="🔊 朗读" Theme="{StaticResource NeuButton}" Classes="small"
                      Command="{Binding SpeakCommand}" />
              <Button Content="📋 复制" Theme="{StaticResource NeuButton}" Classes="small"
                      Command="{Binding CopyCommand}" />
              <Button Theme="{StaticResource NeuButton}" Classes="small"
                      Command="{Binding ToggleFavoriteCommand}">
                <Button.Content>
                  <Binding Path="IsFavorite" StringFormat="⭐ {0}" />
                </Button.Content>
              </Button>
              <Button Content="⚡ 多引擎对比" Theme="{StaticResource NeuButton}" Classes="small accent"
                      Command="{Binding CompareCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Padding="40" Opacity="0.4">
          <TextBlock Text="译文将在此处显示..."
                     HorizontalAlignment="Center" FontStyle="Italic"
                     FontSize="{DynamicResource FontSize.Body}" />
        </Border>

      </StackPanel>
    </Grid>

    <!-- Announcement Bar -->
    <Border Grid.Row="2" Theme="{StaticResource NeuCard}" Classes="inset"
            Background="{DynamicResource BgBrush}" Padding="12,0">
      <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <TextBlock Text="📢" FontSize="12" />
        <TextBlock Text="{Binding AnnouncementText}"
                   FontSize="{DynamicResource FontSize.Small}"
                   Foreground="{DynamicResource AccentBrush}"
                   VerticalAlignment="Center" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
