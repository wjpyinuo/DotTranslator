<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DotTranslator.App.ViewModels"
             xmlns:models="using:DotTranslator.Shared.Models"
             x:Class="DotTranslator.App.Views.HistoryView"
             x:DataType="vm:HistoryViewModel">

  <DockPanel>
    <!-- Search bar -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <TextBox Text="{Binding SearchQuery, Mode=TwoWay}" Watermark="搜索翻译历史..."
               KeyDown="OnSearchKeyDown" Width="300" />
      <Button Content="🔍 搜索" Command="{Binding SearchCommand}" />
      <Button Content="🗑 清空" Command="{Binding ClearAllCommand}" />
      <Button Content="📤 导出" Command="{Binding ExportCommand}" />
    </StackPanel>

    <!-- History list -->
    <ScrollViewer>
      <ItemsControl ItemsSource="{Binding Entries}">
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="models:HistoryEntry">
            <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                    CornerRadius="6" Padding="12" Margin="0,0,0,6">
              <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0" Spacing="4">
                  <TextBlock Text="{Binding SourceText}" TextWrapping="Wrap"
                             MaxLines="2" TextTrimming="CharacterEllipsis" FontSize="13" />
                  <TextBlock Text="{Binding TargetText}" TextWrapping="Wrap"
                             MaxLines="2" TextTrimming="CharacterEllipsis" FontSize="13"
                             Foreground="{DynamicResource SystemControlForegroundAccentBrush}" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding Provider}" FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                  </StackPanel>
                </StackPanel>
                <Button Grid.Column="1" Content="⭐" Click="OnToggleFavorite"
                        Tag="{Binding Id}" FontSize="14" />
                <Button Grid.Column="2" Content="✕" Click="OnDeleteEntry"
                        Tag="{Binding Id}" FontSize="14" />
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</UserControl>
