<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DotTranslator.App.ViewModels"
             x:Class="DotTranslator.App.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <ScrollViewer Padding="16">
    <StackPanel Spacing="16">
      <TextBlock Text="设置" FontSize="20" FontWeight="Bold" />

      <!-- API Keys Section -->
      <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
              CornerRadius="8" Padding="16">
        <StackPanel Spacing="16">
          <TextBlock Text="🔑 翻译引擎凭证" FontSize="16" FontWeight="SemiBold" />
          <TextBlock Text="配置任意一个引擎即可使用，配多个可并行对比。" FontSize="12"
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />

          <ItemsControl ItemsSource="{Binding ProviderCredentials}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:ProviderCredentialItem">
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,8">
                  <StackPanel Spacing="6">
                    <!-- Provider name + free quota -->
                    <TextBlock FontSize="14" FontWeight="SemiBold">
                      <Run Text="{Binding Meta.Name}" />
                    </TextBlock>
                    <TextBlock FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}">
                      <Run Text="免费额度: " />
                      <Run Text="{Binding Meta.FreeQuota}" />
                    </TextBlock>
                    <TextBlock FontSize="11">
                      <Run Text="申请地址: " />
                      <Run Text="{Binding Meta.ApplyUrl}" Foreground="{DynamicResource SystemControlForegroundAccentBrush}" />
                    </TextBlock>
                    <TextBlock FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               TextWrapping="Wrap">
                      <Run Text="{Binding Meta.FieldHints}" />
                    </TextBlock>

                    <!-- Input fields -->
                    <StackPanel Spacing="4">
                      <TextBox Watermark="{Binding Field1Label}" Text="{Binding Value1}"
                               IsVisible="{Binding Field1Label, Converter={x:Static vm:Converters.StringNotEmptyConverter}}" />
                      <TextBox Watermark="{Binding Field2Label}" Text="{Binding Value2}"
                               IsVisible="{Binding HasField2}" />
                      <TextBox Watermark="{Binding Field3Label}" Text="{Binding Value3}"
                               IsVisible="{Binding HasField3}" />
                      <TextBox Watermark="{Binding Field4Label}" Text="{Binding Value4}"
                               IsVisible="{Binding HasField4}" />
                    </StackPanel>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <Button Content="保存所有凭证" Command="{Binding SaveAllCredentialsCommand}"
                  HorizontalAlignment="Left" Classes="accent" />
        </StackPanel>
      </Border>

      <!-- Local API Section -->
      <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
              CornerRadius="8" Padding="16">
        <StackPanel Spacing="8">
          <TextBlock Text="🌐 本地 API" FontSize="16" FontWeight="SemiBold" />
          <TextBlock Text="{Binding LocalApiInfo}" FontSize="12" TextWrapping="Wrap"
                     FontFamily="Consolas,Menlo,monospace" />
          <TextBlock Text="仅允许 127.0.0.1 访问，需 Bearer Token 认证" FontSize="11"
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        </StackPanel>
      </Border>

      <!-- Theme Section -->
      <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
              CornerRadius="8" Padding="16">
        <StackPanel Spacing="12">
          <TextBlock Text="🎨 外观" FontSize="16" FontWeight="SemiBold" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <RadioButton Content="浅色" IsChecked="{Binding Theme, Converter={x:Static vm:Converters.ThemeLightConverter}}" />
            <RadioButton Content="深色" IsChecked="{Binding Theme, Converter={x:Static vm:Converters.ThemeDarkConverter}}" />
            <RadioButton Content="跟随系统" IsChecked="{Binding Theme, Converter={x:Static vm:Converters.ThemeSystemConverter}}" />
          </StackPanel>
          <Button Content="应用主题" Command="{Binding SaveThemeCommand}" HorizontalAlignment="Left" />
        </StackPanel>
      </Border>

      <!-- Data Management -->
      <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
              CornerRadius="8" Padding="16">
        <StackPanel Spacing="12">
          <TextBlock Text="📦 数据管理" FontSize="16" FontWeight="SemiBold" />
          <Button Content="清除所有历史记录" Command="{Binding ClearAllDataCommand}"
                  HorizontalAlignment="Left" />
        </StackPanel>
      </Border>

      <!-- About & Update -->
      <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
              CornerRadius="8" Padding="16">
        <StackPanel Spacing="8">
          <TextBlock Text="ℹ️ 关于" FontSize="16" FontWeight="SemiBold" />
          <TextBlock Text="{Binding AppVersion, StringFormat='DotTranslator v{0}'}" />
          <TextBlock Text="即时翻译桌面工具 · .NET 8 + Avalonia" FontSize="12"
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4">
            <Button Content="检查更新" Command="{Binding CheckUpdateCommand}"
                    IsEnabled="{Binding !IsCheckingUpdate}" HorizontalAlignment="Left" />
            <TextBlock Text="{Binding UpdateStatus}" FontSize="12" VerticalAlignment="Center"
                       Foreground="{DynamicResource SystemControlForegroundAccentBrush}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Status -->
      <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                 Foreground="{DynamicResource SystemControlForegroundAccentBrush}" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
